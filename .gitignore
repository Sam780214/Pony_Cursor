# Python caches (may regenerate under project dirs)
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
venv/
.env

# All local-only artifacts live here (see local-only/README.md)
local-only/*
!local-only/README.md

# pip may still recreate egg-info next to pyproject.toml
opencode/opencode_cli.egg-info/

